{
    "timestamp_format": "%Y-%m-%dT%H:%M:%SZ",
    "log_retention_days": 7,
    "polling_interval_seconds": 10,
    "metrics_to_log": [
        "cpu",
        "ram",
        "network",
        "services",
        "kepserverevents",
        "tag_channels",
        "opcdiagnostics"
    ],
    "metrics_config": {
        "cpu": {
            "prefix": "ns=2;s=IDL.Metrics.CPU"
        },
        "ram": {
            "prefix": "ns=2;s=IDL.Metrics.RAM"
        },
        "network": {
            "prefix": "ns=2;s=IDL.Metrics.Network"
        },
        "services": {
            "_note": "prefix must match the extractor's copy; 'names' is unused by the ingestor but required by the schema, so it's left empty here",
            "prefix": "ns=2;s=IDL.Metrics.Services",
            "names": []
        },
        "kepserverevents": {
            "prefix": "ns=2;s=IDL.Metrics.Events"
        },
        "tag_channels": {
            "_note": "top-level key must match a server's 'name' in servers.json",
            "your-server-name": {
                "channel_name": "ns=2;s=YourChannel.Tags"
            }
        },
        "host_name": {
            "prefix": "ns=2;s=IDL.Metrics"
        },
        "opcdiagnostics": {
            "_note": "prefix must match the extractor's copy; 'log_path' is unused by the ingestor but required by the schema, so it's left empty here",
            "prefix": "ns=2;s=IDL.Metrics.OpcConnections",
            "log_path": ""
        }
    }
}
